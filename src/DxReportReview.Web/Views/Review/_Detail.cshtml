@using DxReportReview.Web.Domain
@model DxReportReview.Web.Models.ReviewDetailModel
@{
    var af = Html.AntiForgeryToken();
    var isPending = Model.Status == ReviewStatus.Pending;
    var isApproved = Model.Status == ReviewStatus.Approved;
    var isRejected = Model.Status == ReviewStatus.Rejected;

    var statusLabel = isPending ? "Open" : isApproved ? "Merged" : "Closed";
    var statusIcon = isPending ? "circle-dot" : isApproved ? "check-circle" : "x-circle";
    var statusColor = isPending ? "#22c55e" : isApproved ? "#3b82f6" : "#ef4444";
    var statusBg = isPending ? "rgba(34,197,94,0.1)" : isApproved ? "rgba(59,130,246,0.1)" : "rgba(239,68,68,0.1)";

    var sInit = Model.SubmitterDisplayName.Length > 0 ? Model.SubmitterDisplayName[0].ToString() : "?";
    var aInit = Model.ApproverDisplayName.Length > 0 ? Model.ApproverDisplayName[0].ToString() : "?";
}

<div data-detail-root data-tabs-vertical="true" style="flex:1;display:flex;flex-direction:column;background:#0c0c0e;min-height:0;overflow:hidden;">

    <div style="padding:20px 28px 0;flex-shrink:0;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <div style="min-width:0;flex:1;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                    <span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:0.6875rem;font-weight:700;color:@statusColor;background:@statusBg;">
                        <i data-lucide="@statusIcon" class="w-3 h-3"></i> @statusLabel
                    </span>
                </div>
                <h1 style="font-size:1.25rem;font-weight:600;color:#fff;margin:0;">
                    @Model.ReportDisplayName <span style="font-weight:400;color:#52525b;">#@Model.Id</span>
                </h1>
                <p style="margin:6px 0 0;font-size:0.6875rem;color:#737373;">
                    @Model.SubmitterDisplayName · @Model.ApproverDisplayName · @Model.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")@if (Model.ProcessedAt.HasValue) {<text> · @Model.ProcessedAt.Value.ToLocalTime().ToString("dd MMM HH:mm")</text>}
                </p>
            </div>
            @if (Model.CanAct)
            {
                <div style="display:flex;gap:8px;flex-shrink:0;margin-left:16px;">
                    <button data-open-modal="rejectModal" class="btn btn-ghost">Reject</button>
                    <button data-open-modal="approveModal" class="btn btn-primary">
                        <i data-lucide="check" class="w-3 h-3"></i> Approve
                    </button>
                </div>
            }
            @if (isRejected && Model.IsSubmitter && Model.BlockReason is null)
            {
                <a href="@Url.Action("ReEdit", new { id = Model.Id })" class="btn btn-ghost" style="text-decoration:none;margin-left:16px;">
                    <i data-lucide="pencil" class="w-3 h-3"></i> Re-edit
                </a>
            }
        </div>

        @if (Model.HasConflict)
        {
            <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;margin-top:14px;border-radius:6px;border:1px solid rgba(234,179,8,0.15);background:rgba(234,179,8,0.05);font-size:0.75rem;color:#eab308;">
                <i data-lucide="alert-triangle" class="w-3.5 h-3.5" style="flex-shrink:0;"></i>
                @(Model.BlockReason ?? "The live report changed after this was sent. You can't approve until that's resolved.")
            </div>
        }

    </div>

    <div style="display:flex;flex:1;min-height:0;border-top:1px solid #1f1f23;">
        <div role="tablist" aria-label="Submission" class="rv-tab-rail">
            <button type="button" role="tab" id="tab-overview" class="rv-tab-btn" data-tab-btn="overview" aria-selected="false" aria-controls="panel-overview">Context</button>
            <button type="button" role="tab" id="tab-changes" class="rv-tab-btn rv-tab-active" data-tab-btn="changes" aria-selected="true" aria-controls="panel-changes">Compare</button>
        </div>
        <div style="flex:1;min-width:0;display:flex;flex-direction:column;min-height:0;background:#111113;">
    <div data-tab-pane="overview" id="panel-overview" role="tabpanel" aria-labelledby="tab-overview" style="display:none;padding:20px 28px;overflow-y:auto;flex:1;">
        <div style="max-width:52rem;">

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div style="border:1px solid #2e2e32;border-radius:8px;overflow:hidden;margin-bottom:24px;">
                    <div style="padding:10px 14px;background:#1a1a1e;border-bottom:1px solid #2e2e32;display:flex;align-items:center;gap:8px;">
                        <span style="width:24px;height:24px;border-radius:50%;background:#fff;color:#111;display:flex;align-items:center;justify-content:center;font-size:0.625rem;font-weight:700;">@sInit</span>
                        <span style="font-size:0.75rem;color:#9ca3af;"><strong style="color:#d1d5db;font-weight:600;">@Model.SubmitterDisplayName</strong> · note</span>
                        <span style="font-size:0.6875rem;color:#52525b;margin-left:auto;">@Model.SubmittedAt.ToLocalTime().ToString("dd MMM HH:mm")</span>
                    </div>
                    <div style="padding:14px 16px;font-size:0.8125rem;color:#d1d5db;line-height:1.65;white-space:pre-wrap;">@Model.Description</div>
                </div>
            }

            <div style="position:relative;padding-left:44px;margin-top:4px;">
                <div style="position:absolute;left:15px;top:4px;bottom:4px;width:2px;background:#2e2e32;"></div>

                <div style="position:relative;padding-bottom:24px;display:flex;align-items:flex-start;gap:12px;">
                    <span style="position:absolute;left:-44px;width:32px;height:32px;border-radius:50%;background:#1a1a1e;border:2px solid #2e2e32;display:flex;align-items:center;justify-content:center;z-index:1;">
                        <i data-lucide="git-commit" class="w-4 h-4" style="color:#6b7280;"></i>
                    </span>
                    <div style="padding-top:4px;">
                        <div style="font-size:0.875rem;color:#d1d5db;line-height:1.5;">
                            <strong style="font-weight:600;">@Model.SubmitterDisplayName</strong>
                            <span style="color:#9ca3af;">submitted for review</span>
                        </div>
                        <div style="font-size:0.75rem;color:#52525b;margin-top:2px;">@Model.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy 'at' HH:mm")</div>
                    </div>
                </div>

                <div style="position:relative;padding-bottom:24px;display:flex;align-items:flex-start;gap:12px;">
                    <span style="position:absolute;left:-44px;width:32px;height:32px;border-radius:50%;background:#1a1a1e;border:2px solid #2e2e32;display:flex;align-items:center;justify-content:center;z-index:1;">
                        <i data-lucide="user-plus" class="w-4 h-4" style="color:#6b7280;"></i>
                    </span>
                    <div style="padding-top:4px;">
                        <div style="font-size:0.875rem;color:#d1d5db;line-height:1.5;">
                            <strong style="font-weight:600;">@Model.ApproverDisplayName</strong>
                            <span style="color:#9ca3af;">set as reviewer</span>
                        </div>
                    </div>
                </div>

                @if (Model.ParentReviewId is { } parentId)
                {
                    <div style="position:relative;padding-bottom:24px;display:flex;align-items:flex-start;gap:12px;">
                        <span style="position:absolute;left:-44px;width:32px;height:32px;border-radius:50%;background:#1a1a1e;border:2px solid #a855f7;display:flex;align-items:center;justify-content:center;z-index:1;">
                            <i data-lucide="rotate-ccw" class="w-4 h-4" style="color:#a855f7;"></i>
                        </span>
                        <div style="padding-top:4px;">
                            <div style="font-size:0.875rem;color:#d1d5db;line-height:1.5;">
                                <span style="color:#9ca3af;">Re-submitted from</span>
                                <a href="#review-@parentId" style="color:#a78bfa;font-weight:600;text-decoration:none;">#@parentId</a>
                            </div>
                        </div>
                    </div>
                }

                @if (isApproved)
                {
                    <div style="position:relative;padding-bottom:@(!string.IsNullOrWhiteSpace(Model.Note) ? "20" : "0")px;display:flex;align-items:flex-start;gap:12px;">
                        <span style="position:absolute;left:-44px;width:32px;height:32px;border-radius:50%;background:rgba(34,197,94,0.12);border:2px solid rgba(34,197,94,0.3);display:flex;align-items:center;justify-content:center;z-index:1;">
                            <i data-lucide="check" class="w-4 h-4" style="color:#22c55e;"></i>
                        </span>
                        <div style="padding-top:4px;">
                            <div style="font-size:0.875rem;color:#d1d5db;line-height:1.5;">
                                <strong style="font-weight:600;">@Model.ApproverDisplayName</strong>
                                <span style="color:#22c55e;font-weight:600;">approved</span>
                            </div>
                            @if (Model.ProcessedAt.HasValue)
                            {
                                <div style="font-size:0.75rem;color:#52525b;margin-top:2px;">@Model.ProcessedAt.Value.ToLocalTime().ToString("dd MMM yyyy 'at' HH:mm")</div>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Note))
                    {
                        <div style="position:relative;padding-bottom:0;margin-left:2px;">
                            <div style="border:1px solid #2e2e32;border-radius:10px;overflow:hidden;">
                                <div style="padding:12px 16px;background:#1a1a1e;border-bottom:1px solid #2e2e32;display:flex;align-items:center;gap:10px;">
                                    <span style="width:24px;height:24px;border-radius:50%;background:rgba(34,197,94,0.1);color:#22c55e;display:flex;align-items:center;justify-content:center;font-size:0.625rem;font-weight:700;">@aInit</span>
                                    <span style="font-size:0.8125rem;color:#d1d5db;font-weight:600;">@Model.ApproverDisplayName</span>
                                    <span style="font-size:0.6875rem;color:#52525b;margin-left:auto;">Approval note</span>
                                </div>
                                <div style="padding:14px 16px;font-size:0.875rem;color:#d1d5db;line-height:1.65;white-space:pre-wrap;">@Model.Note</div>
                            </div>
                        </div>
                    }
                }

                @if (isRejected)
                {
                    <div style="position:relative;padding-bottom:@(!string.IsNullOrWhiteSpace(Model.Note) ? "20" : "0")px;display:flex;align-items:flex-start;gap:12px;">
                        <span style="position:absolute;left:-44px;width:32px;height:32px;border-radius:50%;background:rgba(239,68,68,0.12);border:2px solid rgba(239,68,68,0.3);display:flex;align-items:center;justify-content:center;z-index:1;">
                            <i data-lucide="x" class="w-4 h-4" style="color:#ef4444;"></i>
                        </span>
                        <div style="padding-top:4px;">
                            <div style="font-size:0.875rem;color:#d1d5db;line-height:1.5;">
                                <strong style="font-weight:600;">@Model.ApproverDisplayName</strong>
                                <strong style="color:#ef4444;font-weight:700;">requested changes</strong>
                            </div>
                            @if (Model.ProcessedAt.HasValue)
                            {
                                <div style="font-size:0.75rem;color:#52525b;margin-top:2px;">@Model.ProcessedAt.Value.ToLocalTime().ToString("dd MMM yyyy 'at' HH:mm")</div>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Note))
                    {
                        <div style="position:relative;padding-bottom:0;margin-left:2px;">
                            <div style="border:1px solid #2e2e32;border-radius:10px;overflow:hidden;">
                                <div style="padding:12px 16px;background:#1a1a1e;border-bottom:1px solid #2e2e32;display:flex;align-items:center;gap:10px;">
                                    <span style="width:24px;height:24px;border-radius:50%;background:rgba(239,68,68,0.1);color:#ef4444;display:flex;align-items:center;justify-content:center;font-size:0.625rem;font-weight:700;">@aInit</span>
                                    <span style="font-size:0.8125rem;color:#d1d5db;font-weight:600;">@Model.ApproverDisplayName</span>
                                    <span style="font-size:0.6875rem;color:#52525b;margin-left:auto;">Review feedback</span>
                                </div>
                                <div style="padding:14px 16px;font-size:0.875rem;color:#d1d5db;line-height:1.65;white-space:pre-wrap;">@Model.Note</div>
                            </div>
                        </div>
                    }
                }

                @if (Model.ChildReviewId is { } childId)
                {
                    <div style="position:relative;padding-top:24px;display:flex;align-items:flex-start;gap:12px;">
                        <span style="position:absolute;left:-44px;width:32px;height:32px;border-radius:50%;background:#1a1a1e;border:2px solid #a855f7;display:flex;align-items:center;justify-content:center;z-index:1;">
                            <i data-lucide="rotate-cw" class="w-4 h-4" style="color:#a855f7;"></i>
                        </span>
                        <div style="padding-top:4px;">
                            <div style="font-size:0.875rem;color:#d1d5db;line-height:1.5;">
                                <strong style="font-weight:600;">@Model.SubmitterDisplayName</strong>
                                <span style="color:#9ca3af;">follow-up submission</span>
                                <a href="#review-@childId" style="color:#a78bfa;font-weight:600;text-decoration:none;">#@childId</a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (string.IsNullOrWhiteSpace(Model.Description))
            {
                <p style="margin:1rem 0 0;font-size:0.75rem;color:#52525b;">No extra notes for this submission.</p>
            }
        </div>
    </div>

    <div data-tab-pane="changes" id="panel-changes" role="tabpanel" aria-labelledby="tab-changes" style="display:flex;flex:1;flex-direction:column;min-height:0;overflow:hidden;">
        <div class="rv-diff-toolbar">
            <div class="rv-diff-toolbar-text">
                <span class="rv-diff-toolbar-title">Compare</span>
                <span class="rv-diff-toolbar-sub">Baseline vs proposed. Diff runs on deserialized XtraReport layouts; borders mark added, changed, or removed controls.</span>
            </div>
            <div class="rv-diff-legend" aria-label="Legend">
                <span><span class="rv-leg-dot rv-leg-dot--add"></span>Added</span>
                <span><span class="rv-leg-dot rv-leg-dot--mod"></span>Modified</span>
                <span><span class="rv-leg-dot rv-leg-dot--rem"></span>Removed</span>
            </div>
        </div>
        <div style="display:flex;flex:1;min-height:0;gap:1px;background:#2e2e32;">
            <div style="flex:1;display:flex;flex-direction:column;min-height:0;background:#111113;">
                <div style="padding:6px 14px;background:#1a1a1e;font-size:0.6875rem;font-weight:600;color:#6b7280;flex-shrink:0;border-bottom:1px solid #2e2e32;">
                    Baseline (current)
                </div>
                <div style="flex:1;min-height:0;margin:10px;border:1px solid #2e2e32;border-radius:6px;overflow:hidden;background:#fff;">
                    <iframe src="@Model.CurrentViewerUrl" title="Current"
                            style="width:100%;height:100%;border:none;display:block;"></iframe>
                </div>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;min-height:0;background:#111113;">
                <div style="padding:6px 14px;background:#1a1a1e;font-size:0.6875rem;font-weight:600;color:#6b7280;flex-shrink:0;border-bottom:1px solid #2e2e32;">
                    Proposed
                </div>
                <div style="flex:1;min-height:0;margin:10px;border:1px solid #2e2e32;border-radius:6px;overflow:hidden;background:#fff;">
                    <iframe src="@Model.ProposedViewerUrl" title="Proposed"
                            style="width:100%;height:100%;border:none;display:block;"></iframe>
                </div>
            </div>
        </div>
    </div>
        </div>
    </div>
</div>

@if (Model.CanAct)
{
    <div data-modal-backdrop id="approveModal" role="dialog" aria-modal="true" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);align-items:center;justify-content:center;z-index:50;">
        <div style="width:100%;max-width:26rem;border-radius:10px;background:#1a1a1e;border:1px solid #2e2e32;box-shadow:0 20px 40px rgba(0,0,0,0.5);overflow:hidden;">
            <div style="padding:14px 20px;border-bottom:1px solid #2e2e32;background:#222226;">
                <h3 style="margin:0;font-size:0.875rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px;">
                    <i data-lucide="check-circle" class="w-4 h-4" style="color:#22c55e;"></i> Approve
                </h3>
            </div>
            <form data-ajax="true" data-review-id="@Model.Id" method="post" action="@Url.Action("Approve", new { id = Model.Id })">
                @af
                <div style="padding:20px;">
                    <label style="display:block;font-size:0.75rem;font-weight:600;color:#d1d5db;margin-bottom:6px;">Note <span style="font-weight:400;color:#6b7280;">(required)</span></label>
                    <textarea name="note" data-required-note rows="3"
                              style="width:100%;border:1px solid #2e2e32;background:#222226;border-radius:6px;padding:10px 12px;font-size:0.8125rem;color:#e5e7eb;outline:none;resize:none;font-family:inherit;box-sizing:border-box;"
                              onfocus="this.style.borderColor='#3f3f46'" onblur="this.style.borderColor='#2e2e32'"
                              placeholder="Add a note..."></textarea>
                </div>
                <div style="padding:10px 20px;background:#222226;border-top:1px solid #2e2e32;display:flex;justify-content:flex-end;gap:8px;">
                    <button type="button" data-close-modal class="btn btn-ghost">Cancel</button>
                    <button type="submit" data-submit-btn class="btn btn-primary">Approve</button>
                </div>
            </form>
        </div>
    </div>

    <div data-modal-backdrop id="rejectModal" role="dialog" aria-modal="true" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);align-items:center;justify-content:center;z-index:50;">
        <div style="width:100%;max-width:26rem;border-radius:10px;background:#1a1a1e;border:1px solid #2e2e32;box-shadow:0 20px 40px rgba(0,0,0,0.5);overflow:hidden;">
            <div style="padding:14px 20px;border-bottom:1px solid #2e2e32;background:#222226;">
                <h3 style="margin:0;font-size:0.875rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px;">
                    <i data-lucide="x-circle" class="w-4 h-4" style="color:#ef4444;"></i> Request changes
                </h3>
            </div>
            <form data-ajax="true" data-review-id="@Model.Id" method="post" action="@Url.Action("Reject", new { id = Model.Id })">
                @af
                <div style="padding:20px;">
                    <label style="display:block;font-size:0.75rem;font-weight:600;color:#d1d5db;margin-bottom:6px;">Reason <span style="font-weight:400;color:#6b7280;">(required)</span></label>
                    <textarea name="note" data-required-note rows="3"
                              style="width:100%;border:1px solid #2e2e32;background:#222226;border-radius:6px;padding:10px 12px;font-size:0.8125rem;color:#e5e7eb;outline:none;resize:none;font-family:inherit;box-sizing:border-box;"
                              onfocus="this.style.borderColor='#3f3f46'" onblur="this.style.borderColor='#2e2e32'"
                              placeholder="Explain what needs to change..."></textarea>
                </div>
                <div style="padding:10px 20px;background:#222226;border-top:1px solid #2e2e32;display:flex;justify-content:flex-end;gap:8px;">
                    <button type="button" data-close-modal class="btn btn-ghost">Cancel</button>
                    <button type="submit" data-submit-btn class="btn btn-danger">Reject</button>
                </div>
            </form>
        </div>
    </div>
}
