@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Error";
}
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1rem;">
    <div style="text-align:center;max-width:24rem;">
        <div style="width:4rem;height:4rem;border-radius:9999px;background:rgba(239,68,68,0.1);color:#f87171;display:inline-flex;align-items:center;justify-content:center;margin-bottom:1rem;">
            <i data-lucide="alert-triangle" class="w-8 h-8"></i>
        </div>
        <h1 style="font-size:1.25rem;font-weight:600;color:#fff;margin:0 0 0.5rem;">Something went wrong</h1>
        <p style="font-size:0.875rem;color:#6b7280;margin:0 0 1.5rem;">An unexpected error occurred. Please try again or sign in again.</p>
        <a href="@Url.Action("Login", "Auth")"
           style="display:inline-flex;align-items:center;padding:0.625rem 1rem;background:#fff;color:#000;font-size:0.875rem;font-weight:500;border-radius:0.5rem;text-decoration:none;">
            Back to Login
        </a>
    </div>
</div>
