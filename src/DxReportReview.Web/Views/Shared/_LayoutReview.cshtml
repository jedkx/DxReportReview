@using DxReportReview.Web.Infrastructure
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — DxReportReview</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/review.css" asp-append-version="true" />
    <script src="https://unpkg.com/lucide@0.577.0"></script>
</head>
@{
    var currentUser = User.Identity?.Name ?? "";
    var isAlice = currentUser == "Alice";
    var otherUser = isAlice ? "bob" : "alice";
    var otherLabel = isAlice ? "Bob" : "Alice";
    var currentRole = isAlice ? "Designer" : "Approver";
    var currentInitial = currentUser.Length > 0 ? currentUser[0].ToString() : "?";
}
<body style="margin:0;font-family:system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;overflow:hidden;background:#111113;color:#e5e7eb;">
    <header style="height:48px;border-bottom:1px solid #2e2e32;background:#1a1a1e;display:flex;align-items:center;flex-shrink:0;z-index:30;position:relative;">
        <div style="display:flex;align-items:center;justify-content:space-between;width:100%;padding:0 16px;">
            <div style="display:flex;align-items:center;gap:16px;">
                <a href="/" style="font-weight:600;color:#fff;display:flex;align-items:center;font-size:0.8125rem;gap:6px;text-decoration:none;">
                    <i data-lucide="git-pull-request" class="w-4 h-4" style="color:#6b7280;"></i>
                    DxReportReview
                </a>
                <span style="width:1px;height:20px;background:#2e2e32;"></span>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <nav style="display:flex;align-items:center;gap:4px;">
                        @if (User.IsInRole(Roles.Designer))
                        {
                            <a href="@Url.Action("Designer", "Report", new { id = 1 })" class="nav-link">Designer</a>
                        }
                        <a href="@Url.Action("Index", "Review")" class="nav-link active" style="display:inline-flex;align-items:center;">Reviews @await Component.InvokeAsync("PendingBadge")</a>
                    </nav>
                }
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div style="display:flex;align-items:center;gap:8px;">
                    <div style="display:flex;align-items:center;gap:6px;padding:3px 10px 3px 3px;border-radius:6px;background:#222226;border:1px solid #2e2e32;">
                        <span style="width:24px;height:24px;border-radius:50%;background:@(isAlice ? "#fff" : "#52525b");color:@(isAlice ? "#111" : "#e5e7eb");display:flex;align-items:center;justify-content:center;font-size:0.6875rem;font-weight:700;">@currentInitial</span>
                        <span style="font-size:0.75rem;font-weight:500;color:#d1d5db;">@currentUser</span>
                        <span style="font-size:0.5625rem;font-weight:600;color:#6b7280;background:#1a1a1e;padding:1px 5px;border-radius:3px;text-transform:uppercase;letter-spacing:0.04em;">@currentRole</span>
                    </div>
                    <form asp-controller="Auth" asp-action="Switch" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="username" value="@otherUser" />
                        <button type="submit" class="btn-switch">
                            <i data-lucide="arrow-left-right" class="w-3 h-3"></i>
                            @otherLabel
                        </button>
                    </form>
                    <form asp-controller="Auth" asp-action="Logout" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-icon" style="font-size:0.6875rem;" aria-label="Logout">
                            <i data-lucide="log-out" class="w-3.5 h-3.5"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </header>
    @RenderBody()

    <script>
    // Review detail: vertical tabs (Context / Compare), lazy diff iframes, approve/reject modals with AJAX.
    function initDetailPanel(scope) {
        scope = scope || document;
        var root = scope.querySelector('[data-detail-root]');
        var tabs = scope.querySelectorAll('[data-tab-btn]');
        var panes = scope.querySelectorAll('[data-tab-pane]');
        var diffLoaded = false;

        var vertical = root && root.getAttribute('data-tabs-vertical') === 'true';
        tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
                var t = this.getAttribute('data-tab-btn');
                if (vertical) {
                    tabs.forEach(function (b) {
                        b.classList.remove('rv-tab-active');
                        b.setAttribute('aria-selected', 'false');
                    });
                    this.classList.add('rv-tab-active');
                    this.setAttribute('aria-selected', 'true');
                } else {
                    tabs.forEach(function (b) { b.style.color = '#6b7280'; b.style.borderBottomColor = 'transparent'; });
                    this.style.color = '#fff'; this.style.borderBottomColor = '#fff';
                }
                panes.forEach(function (p) { p.style.display = 'none'; });
                var pane = scope.querySelector('[data-tab-pane="' + t + '"]');
                if (pane) pane.style.display = t === 'changes' ? 'flex' : '';
                if (root) root.style.overflow = t === 'changes' ? 'hidden' : '';
                if (t === 'changes' && !diffLoaded) {
                    diffLoaded = true;
                    scope.querySelectorAll('iframe[data-src]').forEach(function (f) {
                        if (!f.src || f.src === 'about:blank') f.src = f.getAttribute('data-src');
                    });
                }
            });
        });

        var lastFocused = null;
        scope.querySelectorAll('[data-open-modal]').forEach(function (b) {
            b.addEventListener('click', function () {
                var m = document.getElementById(this.getAttribute('data-open-modal'));
                if (m) {
                    lastFocused = document.activeElement;
                    m.style.display = 'flex';
                    var first = m.querySelector('textarea, input, button');
                    if (first) first.focus();
                }
            });
        });
        function closeModal(m) {
            if (!m) return;
            m.style.display = 'none';
            if (lastFocused) lastFocused.focus();
        }
        scope.querySelectorAll('[data-close-modal]').forEach(function (b) {
            b.addEventListener('click', function () { closeModal(this.closest('[data-modal-backdrop]')); });
        });
        scope.querySelectorAll('[data-modal-backdrop]').forEach(function (m) {
            m.addEventListener('keydown', function (e) {
                if (e.key !== 'Tab') return;
                var focusable = m.querySelectorAll('button, textarea, input, select');
                if (!focusable.length) return;
                var first = focusable[0], last = focusable[focusable.length - 1];
                if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
                else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
            });
            m.addEventListener('click', function (e) { if (e.target === m) closeModal(m); });
        });

        scope.querySelectorAll('[data-required-note]').forEach(function (ta) {
            var form = ta.closest('form') || ta.closest('[data-modal-backdrop]');
            var btn = form ? form.querySelector('[data-submit-btn]') : null;
            if (btn) {
                btn.disabled = true; btn.style.opacity = '0.4';
                ta.addEventListener('input', function () {
                    var ok = this.value.trim().length > 0;
                    btn.disabled = !ok; btn.style.opacity = ok ? '1' : '0.4';
                });
            }
        });

        scope.querySelectorAll('form[data-ajax="true"]').forEach(function (f) {
            f.addEventListener('submit', function (e) {
                e.preventDefault();
                var btn = f.querySelector('[data-submit-btn]');
                var orig = btn ? btn.textContent : '';
                if (btn) { btn.disabled = true; btn.textContent = orig.trim() + '\u2026'; }
                var reviewId = f.getAttribute('data-review-id');

                fetch(f.action, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: new FormData(f) })
                    .then(function (r) {
                        if (!r.ok) return r.json().then(function (d) { throw new Error(d.error || 'Request failed'); });
                        return r.json();
                    })
                    .then(function (d) {
                        if (!d.ok) throw new Error(d.error || 'Failed');
                        closeModal(f.closest('[data-modal-backdrop]'));
                        if (typeof refreshAfterAction === 'function') refreshAfterAction(reviewId, d.status);
                    })
                    .catch(function (err) {
                        if (btn) {
                            btn.disabled = false;
                            btn.textContent = err.message || 'Failed';
                            btn.style.color = '#ef4444';
                            setTimeout(function () { btn.textContent = orig; btn.style.color = ''; }, 2000);
                        }
                    });
            });
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') scope.querySelectorAll('[data-modal-backdrop]').forEach(function (m) { closeModal(m); });
        });
    }
    </script>
    @if (IsSectionDefined("Scripts")) { @RenderSection("Scripts") }
    <script>lucide.createIcons();</script>
</body>
</html>
